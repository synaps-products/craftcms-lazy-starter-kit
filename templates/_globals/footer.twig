{% set imprint = craft.entries.slug('imprint').one() %}
{% set privacy = craft.entries.slug('privacy-policy').one() %}
{% set search = craft.entries.slug('search').one() %}

<footer class="blocks blocks--footer bg-canvas border-t-4 border-ink mt-12">
  <div class="blocks__content text-center space-y-6">

    <h2 class="ui-h2 text-ink">Clean. Modular.<br>Ready for real-world use.</h2>

    <p class="text-ink md:text-lg max-w-2xl mx-auto">I'm <strong>Andi Grether</strong>, a freelance full-stack developer specialized in Craft CMS. I work with creative agencies and design teams
      who need a reliable technical partner. Visit <a href="https://webworker.me"
                                                      class="font-bold underline decoration-2 underline-offset-2 decoration-ink hover:decoration-ink-on transition-colors">webworker.me</a></p>

    <nav>
      <ul class="flex flex-wrap gap-6 justify-center">
        {% if search %}
          <li><a href="{{ search.url }}" class="ui-link">{{ search.title }}</a></li>
        {% endif %}
        {% if imprint %}
          <li><a href="{{ imprint.url }}" class="ui-link">{{ imprint.title }}</a></li>
        {% endif %}
        {% if privacy %}
          <li><a href="{{ privacy.url }}" class="ui-link">{{ privacy.title }}</a></li>
        {% endif %}
      </ul>
    </nav>

  </div>

  <div class="blocks__feature border-t-2 border-ink mt-6 pt-0">
    <div class="grid grid-cols-2 items-center gap-4 pt-2">
      <p class="ui-bold text-ink text-lg whitespace-nowrap">Craft CMS Lazy Kit</p>
