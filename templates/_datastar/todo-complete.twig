{% set todoId = signals.todoId ?? '' %}
{% set todos = craft.app.session.get('todos', []) %}

{% if todoId %}
  {% set updatedTodos = [] %}
  {% for todo in todos %}
    {% if todo.id == todoId %}
      {% set updatedTodos = updatedTodos | merge([todo | merge({ completed: not todo.completed })]) %}
    {% else %}
      {% set updatedTodos = updatedTodos | merge([todo]) %}
    {% endif %}
  {% endfor %}
  {% do craft.app.session.set('todos', updatedTodos) %}
{% endif %}

{% patchelements with {useViewTransition: true} %}
  {% include '_datastar/todo-list' %}
{% endpatchelements %}
