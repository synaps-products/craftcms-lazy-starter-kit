{% set builder = builder ?? false %}
{% set image = entry.image.eagerly().one() ?? null %}
{% set button = entry.button %}

{% extends builder ? "_partials/matrix.twig" : "_partials/cke.twig" %}
{% set classWrapper = builder ? 'blocks blocks--cta' : 'inlines inlines--cta' %}
{% set classContent = builder ? 'blocks__popout' : '' %}

{% block content %}
  <div class="ui-neo bg-pop-dim p-6 md:p-16 flex flex-col items-start gap-6 ui-lift">
    <p class="ui-h1 text-ink">
      {{ entry.headline|nl2br }}
    </p>
    {% if entry.text %}
      <div class="prose md:prose-lg text-ink">
        {{ entry.text }}
      </div>
    {% endif %}
    {% if button %}
      {% include "_components/button.twig" with {
        label: button.label ?? button.title,
        url: button.url,
        size: 'lg',
        class: 'ui-btn--dark',
        target: button.target ? '_blank' : null,
        rel: button.target ? 'noopener noreferrer' : null,
        ariaLabel: button.ariaLabel,
        download: button.download,
      } only %}
    {% endif %}
  </div>
{% endblock %}
