{% extends '_layouts/base' %}

{% set seomate = {
  meta: {
    title: "Hypermedia Todo List – Craft CMS & Datastar Demo",
    description: "A hypermedia TodoList built with Craft CMS and Datastar. No JavaScript framework, no database — reactive CRUD via SSE endpoints and HTML over the wire.",
  },
} %}

{% block main %}
  <header class="blocks blocks--header">
    <div class="blocks__content">
      <h1 class="ui-h1">Hypermedia TodoList</h1>
    </div>
  </header>

  <section class="blocks blocks--text">
    <div class="blocks__content prose md:prose-lg lg:prose-xl">
      <p>
        A hypermedia TodoList built with <strong>Craft CMS</strong> and <strong>Datastar</strong> — no JavaScript framework, no database.
        All interactions are handled by SSE endpoints that stream HTML fragments back to the browser.
        A practical example of the <strong>hypermedia</strong> approach: server-rendered state, HTML over the wire, progressive enhancement.
      </p>
    </div>
  </section>

  <noscript>
    <style>#todo-app {
        display: none;
      }</style>
    <section class="blocks blocks--text">
      <div class="blocks__content">
        <p class="ui-neo bg-pop inline-block px-4 py-2 ui-bold">This demo requires JavaScript.</p>
      </div>
    </section>
  </noscript>

  <section
    id="todo-app"
    class="blocks blocks--todo"
    data-signals="{ todoInput: '', todoId: '', todoError: '' }"
    data-init="{{ datastar.get('_datastar/todo-list') }}"
    data-indicator:fetching
  >
    <div class="blocks__content">
      <div class="flex gap-3 mb-6">
        <div class="relative flex-1">
          <input
            type="text"
            name="totoInput"
            class="ui-input w-full"
            placeholder="What needs to be done?"
            data-on:input="$todoInput = el.value"
            data-effect="el.value = $todoInput"
            data-on:keydown="evt.key === 'Enter' && {{ datastar.post('_datastar/todo-add') }}"
            data-attr:disabled="$fetching"
            maxlength="200"
            autocomplete="off"
            aria-label="New todo"
          />
          <div data-show="$fetching" class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
            <svg class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
        </div>
        <button
          type="button"
          class="ui-btn shrink-0"
          data-on:click="{{ datastar.post('_datastar/todo-add') }}"
          data-attr:disabled="$fetching"
        >
          Add
        </button>
      </div>
      <p class="mb-3 text-sm ui-bold text-pop" data-show="$todoError" data-text="$todoError"></p>
      <div class="relative ui-neo border-2 border-ink overflow-hidden">
        <ul id="todo-list" class="divide-y-2 divide-ink min-h-[60px]"></ul>
      </div>
    </div>
  </section>
{% endblock %}
